# === Production (obligatoire) ===
NODE_ENV=production
MAIL_SERVER_PORT=8787
APP_BASE_URL=https://www.votre-domaine.ch
TRUST_PROXY=1

# === E-mail (Gmail : mot de passe d'application) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=unifreshbynk@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM=UniFresh <unifreshbynk@gmail.com>
ADMIN_REVIEW_EMAIL=unifreshbynk@gmail.com

# === Application ===
SERVICE_AREA_LABEL=Suisse romande (Genève, Vaud, Valais, Fribourg, Neuchâtel, Jura)
ADMIN_TOKEN_EXPIRY=3600000

# Front sur un autre domaine que l'API (optionnel)
# CORS_ORIGINS=https://www.votre-domaine.ch
# VITE_API_URL=https://api.votre-domaine.ch

# === Sauvegardes SQLite (data/unifresh.db) ===
BACKUP_INTERVAL_MS=21600000
BACKUP_KEEP_COUNT=14
MAINTENANCE_INTERVAL_MS=900000
